{
  "name": "super-utils",
  "version": "1.0.0",
  "description": "Electron 文件管理工具",
  "main": "electron/main.js",
  "scripts": {
    "========== 开发命令 ==========": "",
    "dev": "concurrently \"pnpm dev:backend\" \"pnpm dev:frontend\"",
    "dev:web": "concurrently \"pnpm dev:backend\" \"pnpm dev:frontend:web\"",
    "dev:backend": "cd server && pnpm dev",
    "dev:frontend": "vite",
    "dev:frontend:web": "vite --config vite.web.config.ts",
    "========== 构建命令 ==========": "",
    "build": "pnpm build:backend && pnpm build:frontend",
    "build:backend": "cd server && pnpm build",
    "build:frontend": "tsc && vite build",
    "========== 启动命令 ==========": "",
    "start": "pnpm start:backend",
    "start:backend": "cd server && pnpm start",
    "========== 打包命令 ==========": "",
    "pack": "pnpm build && electron-builder --dir",
    "pack:installer": "pnpm build && electron-builder --publish=never",
    "========== 工具命令 ==========": "",
    "typecheck": "tsc --noEmit",
    "peerjs": "peerjs --port 8999 --ip 0.0.0.0",
    "========== 子项目命令 ==========": "",
    "server": "cd server && pnpm",
    "admin": "cd admin && pnpm"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "fast-glob": "^3.3.0",
    "lodash-es": "^4.17.23",
    "mammoth": "^1.11.0",
    "monaco-editor": "^0.55.1",
    "mysql2": "^3.6.0",
    "node-cron": "^3.0.0",
    "pdfjs-dist": "^5.4.624",
    "pinia": "^2.1.0",
    "plyr": "^3.8.4",
    "qrcode": "^1.5.4",
    "qrcode.vue": "^3.8.0",
    "typeorm": "^0.3.0",
    "vconsole": "^3.15.1",
    "vue": "^3.4.0",
    "vue-router": "^4.6.4",
    "vuetify": "^3.6.0"
  },
  "devDependencies": {
    "@electron/asar": "^4.1.0",
    "@types/qrcode": "^1.5.6",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "concurrently": "^8.2.0",
    "electron": "32.0.0",
    "electron-builder": "^24.9.0",
    "sass": "1.32.13",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vite-plugin-monaco-editor": "^1.1.0",
    "wait-on": "^7.2.0"
  }
}
