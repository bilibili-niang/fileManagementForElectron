{
  "name": "super-utils-server",
  "version": "1.0.0",
  "description": "Backend server for Super Utils",
  "main": "dist/index.js",
  "scripts": {
    "========== 开发命令 ==========": "",
    "dev": "tsx watch src/index.ts",
    "dev:quiet": "tsx watch src/index.ts 2>nul",
    "========== 构建命令 ==========": "",
    "build": "tsc",
    "========== 启动命令 ==========": "",
    "start": "node dist/index.js",
    "start:quiet": "node dist/index.js 2>nul",
    "========== 测试命令 ==========": "",
    "test": "tsx src/test/runTests.ts",
    "test:api": "tsx src/test/runTests.ts"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "chokidar": "^3.5.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.6.5",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.4",
    "prisma": "^7.5.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
