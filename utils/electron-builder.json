{
  "appId": "com.superutils.app",
  "productName": "Super Utils",
  "directories": {
    "output": "app-build",
    "buildResources": "build"
  },
  "files": [
    "dist/**/*",
    "electron/**/*",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "server/dist",
      "to": "server"
    }
  ],
  "electronDist": "node_modules/electron/dist",
  "win": {
    "target": "nsis",
    "icon": "build/icon.ico",
    "signAndEditExecutable": false
  },
  "mac": {
    "target": "dmg",
    "icon": "build/icon.icns"
  },
  "linux": {
    "target": "AppImage",
    "icon": "build/icon.png"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  }
}
